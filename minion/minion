#!/bin/bash
set -e

# Task 3.1 & 3.2: Final Pipeline & "One-Shot" Loop Enforcement
# Combines branch creation, Goose wrapper execution, CI loop, and PR submission.

if [ "$#" -lt 1 ]; then
    echo "Usage: minion <task_instruction> [test_command]"
    exit 1
fi

TASK_INSTRUCTION=$1
TEST_COMMAND=${2:-"npm test"}

# Set up branch
TASK_SLUG=$(echo "$TASK_INSTRUCTION" | tr '[:upper:]' '[:lower:]' | sed -e 's/[^a-zA-Z0-9]/-/g' | cut -c 1-30 | sed 's/-$//')
BRANCH_NAME="minion-work-$TASK_SLUG"

echo "==> Setting up branch: $BRANCH_NAME"
git checkout -b "$BRANCH_NAME" || git checkout "$BRANCH_NAME"

# Strike counter for tests
MAX_STRIKES=2
STRIKE=0

# Ensure wrapper and validation script are executable
chmod +x ./goose_wrapper.py ./validate.py

# First attempt
echo "==> Running Goose for initial attempt: '$TASK_INSTRUCTION'"
./goose_wrapper.py "$TASK_INSTRUCTION"

# CI Loop
while [ $STRIKE -lt $MAX_STRIKES ]; do
    echo "==> Running validation (Attempt $((STRIKE + 1))/$MAX_STRIKES)"
    if ./validate.py "$TEST_COMMAND" --out "correction_prompt.txt"; then
        echo "==> Validation passed!"
        # Commit and PR
        git add .
        git commit -m "[Minion] Automated changes for: $TASK_INSTRUCTION" || true
        git push -u origin "$BRANCH_NAME"

        # We assume gh cli is installed and authenticated
        echo "==> Creating PR..."
        if command -v gh &> /dev/null; then
            gh pr create --title "[Minion] $TASK_INSTRUCTION" --body "Automated changes generated by minion one-shot agent."
            echo "==> PR created successfully!"
        else
            echo "==> 'gh' CLI not found. Skipping PR creation."
        fi
        exit 0
    else
        echo "==> Validation failed. Running Goose with correction prompt..."
        CORRECTION=$(cat correction_prompt.txt)
        ./goose_wrapper.py "$CORRECTION"
        STRIKE=$((STRIKE + 1))
    fi
done

# If we get here, it failed after MAX_STRIKES
echo "==> FAILED TO FIX after $MAX_STRIKES strikes."
echo "Current diff:"
git diff
exit 1
