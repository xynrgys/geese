#!/bin/bash
set -e

# Task 3.1 & 3.2: Final Pipeline & "One-Shot" Loop Enforcement
# Combines branch creation, Goose wrapper execution, CI loop, and PR submission.

if [ "$#" -lt 1 ]; then
    echo "Usage: minion <task_instruction> [test_command]"
    exit 1
fi

TASK_INSTRUCTION=$1
TEST_COMMAND=${2:-"npm test"}

if [ ! -f .minion_container_id ]; then
    echo "Error: .minion_container_id not found. Run setup_env.sh first."
    exit 1
fi
CONTAINER_NAME=$(cat .minion_container_id)

# Set up branch
TASK_SLUG=$(echo "$TASK_INSTRUCTION" | tr '[:upper:]' '[:lower:]' | sed -e 's/[^a-zA-Z0-9]/-/g' | cut -c 1-30 | sed 's/-$//')
BRANCH_NAME="minion-work-$TASK_SLUG"

echo "==> Setting up branch: $BRANCH_NAME inside container $CONTAINER_NAME"
docker exec "$CONTAINER_NAME" bash -c "cd repo && (git checkout -b '$BRANCH_NAME' || git checkout '$BRANCH_NAME')"

# Strike counter for tests
MAX_STRIKES=2
STRIKE=0

# Ensure wrapper and validation script are executable inside the container
docker exec "$CONTAINER_NAME" bash -c "cd repo && chmod +x ./goose_wrapper.py ./validate.py"

# First attempt
echo "==> Running Goose for initial attempt: '$TASK_INSTRUCTION'"
# Notice we disable 'set -e' for the docker exec call to prevent the bash script from failing if goose fails
docker exec "$CONTAINER_NAME" bash -c "cd repo && ./goose_wrapper.py '$TASK_INSTRUCTION'" || true

# CI Loop
while [ $STRIKE -lt $MAX_STRIKES ]; do
    echo "==> Running validation (Attempt $((STRIKE + 1))/$MAX_STRIKES)"
    # Disabling strict error checking locally so `if` handles the failure cleanly
    if docker exec "$CONTAINER_NAME" bash -c "cd repo && ./validate.py '$TEST_COMMAND' --out 'correction_prompt.txt'"; then
        echo "==> Validation passed!"
        # Commit and PR inside the container
        docker exec "$CONTAINER_NAME" bash -c "
            cd repo
            git config user.email 'minion@example.com'
            git config user.name 'Minion Agent'
            git add .
            git commit -m '[Minion] Automated changes for: $TASK_INSTRUCTION' || true
            git push -u origin '$BRANCH_NAME' || echo 'Push skipped (No auth configured)'

            # We assume gh cli is installed and authenticated
            echo '==> Creating PR...'
            if command -v gh &> /dev/null; then
                # gh requires auth, so this assumes the user provided a GITHUB_TOKEN to the container
                gh pr create --title '[Minion] $TASK_INSTRUCTION' --body 'Automated changes generated by minion one-shot agent.' || echo 'PR creation skipped (No auth configured)'
            fi
        "
        exit 0
    else
        echo "==> Validation failed. Running Goose with correction prompt..."
        # Extract the correction prompt
        docker exec "$CONTAINER_NAME" bash -c 'cd repo && ./goose_wrapper.py "$(cat correction_prompt.txt)"' || true
        STRIKE=$((STRIKE + 1))
    fi
done

# If we get here, it failed after MAX_STRIKES
echo "==> FAILED TO FIX after $MAX_STRIKES strikes."
echo "Current diff:"
docker exec "$CONTAINER_NAME" bash -c "cd repo && git diff"
exit 1
